{
  "name": "ya-repo-toc",
  "version": "0.0.1",
  "description": "Generate a markdown Table of Contents for your GitHub repository. Uses git-native file discovery, supports nested .gitignore, and prunes empty directories.",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "publish:dry": "npm publish --dry-run",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major"
  },
  "bin": {
    "ya-repo-toc": "./cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WGriffing/ya-repo-toc.git"
  },
  "keywords": [
    "toc",
    "markdown-toc",
    "table of contents",
    "repo-toc",
    "github",
    "documentation"
  ],
  "author": "WGriffing",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/WGriffing/ya-repo-toc/issues"
  },
  "homepage": "https://github.com/WGriffing/ya-repo-toc#readme",
  "engines": {
    "node": ">=18.3.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
